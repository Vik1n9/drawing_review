      "type": "param-equals",
      "path": "params.low_rise.per_floor_area_threshold.甲",
      "expected": 300,
      "source": {"pdf": "【示例占位】法條清單.pdf", "page": null, "quote": "【示例占位】待以法條 PDF 原文逐字替換（任何一層樓地板面積三〇〇平方公尺以上）"}
    },
    {
      "id": "T-sprinkler-threshold-lowrise",
      "rule_id": "sprinkler-threshold",
      "type": "param-equals",
      "path": "params.low_rise_total_area_threshold.value",
      "expected": 1500,
      "source": {"pdf": "【示例占位】法條清單.pdf", "page": null, "quote": "【示例占位】待以法條 PDF 原文逐字替換（樓地板面積合計一五〇〇平方公尺以上）"}
    },
    {
      "id": "T-exitlight-required-uses",
      "rule_id": "exit-light-threshold",
      "type": "param-equals",
      "path": "params.required_uses",
      "expected": ["甲", "乙", "丙", "丁"],
      "source": {"pdf": "【示例占位】法條清單.pdf", "page": null, "quote": "【示例占位】待以法條 PDF 原文逐字替換（適用用途類別）"}
    },
    {
      "id": "T-emergency-light-required",
      "rule_id": "emergency-light-threshold",
      "type": "param-equals",
