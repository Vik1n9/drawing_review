      "source": {"pdf": "【示例占位】法條清單.pdf", "page": null, "quote": "【示例占位】待以法條 PDF 原文逐字替換（緊急照明設備應設範圍與但書）"}
    },
    {
      "id": "T-smoke-exhaust-threshold",
      "rule_id": "smoke-exhaust-threshold",
      "type": "param-equals",
      "path": "params.total_area_threshold.value",
      "expected": 500,
      "source": {"pdf": "【示例占位】法條清單.pdf", "page": null, "quote": "【示例占位】待以法條 PDF 原文逐字替換（樓地板面積合計五〇〇平方公尺以上）"}
    }
  ]
}
