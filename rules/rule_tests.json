      "type": "param-equals",
      "path": "params.total_area_threshold_other_uses.value",
      "expected": 150,
      "source": {"pdf": "【示例占位】法條清單.pdf", "page": null, "quote": "【示例占位】待以法條 PDF 原文逐字替換（總樓地板面積一五〇平方公尺以上）"}
    },
    {
      "id": "T-hydrant-threshold-lowrise-甲",
